# ── DocketZero Backend Environment Variables ──────────────────────────────────
# Copy this file to .env for local development
# Set these as Environment Variables in your Render dashboard for production

# ── Database ──────────────────────────────────────────────────────────────────
# Render provides this automatically when you attach a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/docketzero

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Email / SMTP (DreamCompute) ───────────────────────────────────────────────
# Your DreamCompute mail server hostname
SMTP_HOST=mail.docketzero.com
# 587 for TLS (recommended), 465 for SSL, 25 for plain (not recommended)
SMTP_PORT=587
# The email address sending the mail
SMTP_USER=support@docketzero.com
# The password for that email account
SMTP_PASS=your_email_password_here
# Where contact form submissions get delivered
CONTACT_TO_EMAIL=support@docketzero.com

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── CORS (optional — your domain is always allowed) ──────────────────────────
# Add extra allowed origins comma-separated if needed
ALLOWED_ORIGINS=https://docketzero.com,https://www.docketzero.com
